{
    "$schema": "https://raw.githubusercontent.com/microsoft/vscode/main/src/vs/workbench/contrib/mcp/browser/mcp.schema.json",
    "inputs": [
        {
            "id": "github_pat",
            "type": "promptString",
            "description": "GitHub Personal Access Token with read:project scope (for Projects read) or project scope (for Projects write)",
            "password": true
        }
    ],
    "servers": {
        "github": {
            "command": "docker",
            "args": [
                "run",
                "-i",
                "--rm",
                "-e",
                "GITHUB_PERSONAL_ACCESS_TOKEN",
                "ghcr.io/github/github-mcp-server",
                "--toolset",
                "repos,issues,pull_requests,projects"
            ],
            "env": {
                "GITHUB_PERSONAL_ACCESS_TOKEN": "${input:github_pat}"
            }
        }
    }
}
